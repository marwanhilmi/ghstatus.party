{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "githubparty",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server-entry.ts",
  "durable_objects": {
    "bindings": [
      {
        "name": "StatusRoom",
        "class_name": "StatusRoom",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["StatusRoom"],
    },
  ],
}
